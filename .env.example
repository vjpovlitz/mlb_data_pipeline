# SQL Server connection (Windows Auth - no password needed)
MLB_DB_SERVER=localhost
MLB_DB_NAME=mlb_pipeline
MLB_DB_DRIVER=ODBC Driver 17 for SQL Server

# Redis
MLB_REDIS_URL=redis://localhost:6379/0

# Polling intervals (seconds)
MLB_POLL_INTERVAL_LIVE=2.0
MLB_POLL_INTERVAL_IDLE=60.0
MLB_POLL_INTERVAL_PREGAME=30.0

# Storage paths
MLB_DATA_DIR=data
